# ==========================================================
# ShellCrash 配置文件 (精修版 - 2026.03.31)
# ==========================================================

# --- 1. 基础设置 ---
mixed-port: 7890
redir-port: 7892
tproxy-port: 7893
allow-lan: true
mode: Rule
log-level: warning
ipv6: true
external-controller: :9999
external-ui: ui
secret: ""
tun: {enable: true, stack: system, device: utun, auto-route: true, auto-detect-interface: true}
experimental: {ignore-resolve-fail: true}
unified-delay: true
tcp-concurrent: true

sniffer:
  enable: true
  parse-pure-ip: true
  sniff:
    TLS: {ports: [443, 8443], override-destination: true}
    HTTP: {ports: [80, 8080-8880], override-destination: true}
  force-domain:
    - "+" # 尝试嗅探所有流量，Meta 内核会更聪明地还原域名
  skip-domain:
    - "Mijia Cloud" # 排除米家等容易被嗅探干扰的国产设备域名

profile:
  store-selected: true
  store-fake-ip: true

# --- 2. 代理订阅源 ---
proxy-providers:
  MyAirport:
    type: http
    url: "你的订阅链接"
    interval: 86400
    path: ./proxies/airport.yaml
    health-check:
      enable: true
      interval: 600
      url: http://www.gstatic.com/generate_204

# --- 3. DNS 设置 ---
dns:
  enable: true
  listen: :1053
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  respect-rules: true
  default-nameserver: [ 223.5.5.5, 119.29.29.29 ]
  nameserver:
    - 'https://dns.alidns.com/dns-query#h3=true'
    - 'https://doh.pub/dns-query#h3=true'
  proxy-server-nameserver: [https://dns.alidns.com/dns-query]
  nameserver-policy:
    "geosite:cn": [223.5.5.5, 119.29.29.29]
  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "geosite:cn"

